JWT_SECRET=change-me-to-a-long-random-string
MONGO_URI=mongodb://localhost:27017
API_PORT=8000
DEBUG=false

# === Kaggle ===
# kaggle CLI reads credentials from ~/.kaggle/kaggle.json by default.
# These env vars are an alternative for headless / CI environments
# (e.g. GitHub Actions secrets). Local dev uses kaggle.json instead.
KAGGLE_USERNAME=
KAGGLE_KEY=
